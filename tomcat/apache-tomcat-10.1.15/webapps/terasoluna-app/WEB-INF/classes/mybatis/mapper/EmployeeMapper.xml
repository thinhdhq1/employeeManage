<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.terasoluna.app.domain.repository.EmployeeMapper">

    <resultMap id="employeeResultMap" type="com.example.terasoluna.app.domain.model.Employee">
        <id column="EMPLOYEEID" property="employeeId"/>
        <result column="NAME" property="name"/>
        <result column="AGE" property="age"/>
        <result column="BIRTH" property="birth"/>
        <result column="ADDRESS" property="address"/>
        <result column="PHONENUMBER" property="phoneNumber"/>
    </resultMap>

    <sql id="employeeColumns">
        EMPLOYEEID, NAME, AGE, BIRTH, ADDRESS, PHONENUMBER
    </sql>

    <sql id="searchWhere">
        <where>
            1 = 1
            <if test="criteria.employeeId != null">
                AND TO_CHAR(EMPLOYEEID) LIKE '%' || #{criteria.employeeId} || '%'
            </if>
            <if test="criteria.name != null and criteria.name != ''">
                AND NAME LIKE '%' || #{criteria.name} || '%'
            </if>
            <if test="criteria.age != null">
                AND AGE = #{criteria.age}
            </if>
            <if test="criteria.birth != null and criteria.birth != ''">
                AND BIRTH LIKE '%' || #{criteria.birth} || '%'
            </if>
            <if test="criteria.address != null and criteria.address != ''">
                AND ADDRESS LIKE '%' || #{criteria.address} || '%'
            </if>
            <if test="criteria.phoneNumber != null and criteria.phoneNumber != ''">
                AND PHONENUMBER LIKE '%' || #{criteria.phoneNumber} || '%'
            </if>
        </where>
    </sql>

    <select id="search" resultMap="employeeResultMap">
        SELECT
        <include refid="employeeColumns"/>
        FROM EMPLOYEE
        <include refid="searchWhere"/>
        ORDER BY EMPLOYEEID
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

    <select id="count" resultType="int">
        SELECT COUNT(*)
        FROM EMPLOYEE
        <include refid="searchWhere"/>
    </select>

    <select id="findById" resultMap="employeeResultMap">
        SELECT
        <include refid="employeeColumns"/>
        FROM EMPLOYEE
        WHERE EMPLOYEEID = #{employeeId}
    </select>

    <update id="update">
        UPDATE EMPLOYEE
        SET NAME = #{name},
            AGE = #{age},
            BIRTH = #{birth},
            ADDRESS = #{address},
            PHONENUMBER = #{phoneNumber}
        WHERE EMPLOYEEID = #{employeeId}
    </update>

</mapper>
